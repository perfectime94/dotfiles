#!/bin/zsh

case $BUTTON in
    1) amixer set -q Master toggle ;;
    4) amixer set -q Master 5%+ unmute ;;
	5) amixer set -q Master 5%- unmute ;;
esac

sound=$(amixer get Master | awk '$0~/%/{print $4}' | tr -d '[]%' | tr -d " ")
muted=$(amixer get Master | awk '{print $6}' | tr -d '[]' | tail -n1 | tr -d " ")

case $muted in
on)
    if [[ $sound -le 33 ]]; then
        print "奄 $sound"
    elif [[ $sound -gt 33 && $sound -le 66 ]]; then
        print "奔 $sound"
    elif [[ $sound -gt 66 ]]; then
        print "墳 $sound"
    fi
    ;;
off)
    print "ﱝ Muted"
    ;;
esac
