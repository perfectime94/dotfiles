#!/usr/bin/env zsh

sound=$(amixer get Master | awk '$0~/%/{print $4}' | tr -d '[]%')
muted=$(amixer get Master | awk '{print $6}' | tr -d '[]' | tail -n1)

case $muted in
on)
    if [[ $sound -le 33 ]]; then
        echo "奄 $sound"
    elif [[ $sound -gt 33 && $sound -le 66 ]]; then
        echo "奔 $sound"
    elif [[ $sound -gt 66 ]]; then
        echo "墳 $sound"
    fi
    ;;
off)
    echo "ﱝ Muted"
    ;;
esac
