#!/bin/zsh

case $BUTTON in
    4) xbacklight -inc 10 ;;
	5) xbacklight -dec 10 ;;
esac

brightness=$(xbacklight -get)

if [[ $brightness -le 15 ]]; then
    print "´ùÖ $brightness"
elif [[ $brightness -gt 15 && $brightness -le 30 ]]; then
    print "´ùÜ $brightness"
elif [[ $brightness -gt 30 && $brightness -le 45 ]]; then
    print "´ùø $brightness"
elif [[ $brightness -gt 45 && $brightness -le 60 ]]; then
    print "´ù£ $brightness"
elif [[ $brightness -gt 60 && $brightness -le 75 ]]; then
    print "´ùØ $brightness"
elif [[ $brightness -gt 75 && $brightness -le 90 ]]; then
    print "´ù× $brightness"
elif [[ $brightness -gt 90 ]]; then
    print "´ùƒ $brightness"
fi
