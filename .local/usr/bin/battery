#!/bin/sh

capacity=$(cat /sys/class/power_supply/BAT0/capacity)

case $(cat /sys/class/power_supply/BAT0/status) in
Discharging)
    if [[ $capacity -le 10 ]]; then
        echo "ÔēĻ $capacity"
    elif [[ $capacity -gt 10 && $capacity -le 20 ]]; then
        echo "Ôēļ $capacity"
    elif [[ $capacity -gt 20 && $capacity -le 30 ]]; then
        echo "ÔēĽ $capacity"
    elif [[ $capacity -gt 30 && $capacity -le 40 ]]; then
        echo "Ôēľ $capacity"
    elif [[ $capacity -gt 40 && $capacity -le 50 ]]; then
        echo "ÔēĹ $capacity"
    elif [[ $capacity -gt 50 && $capacity -le 60 ]]; then
        echo "Ôēĺ $capacity"
    elif [[ $capacity -gt 60 && $capacity -le 70 ]]; then
        echo "ÔēŅ $capacity"
    elif [[ $capacity -gt 70 && $capacity -le 80 ]]; then
        echo "ÔĖÄ $capacity"
    elif [[ $capacity -gt 80 && $capacity -le 90 ]]; then
        echo "ÔĖĀ $capacity"
    elif [[ $capacity -gt 90 ]]; then
        echo "Ôēł $capacity"
    fi
    ;;

Charging)
    if [[ $capacity -le 20 ]]; then
        echo "ÔĖÖ $capacity"
    elif [[ $capacity -gt 20 && $capacity -le 30 ]]; then
        echo "ÔĖÜ $capacity"
    elif [[ $capacity -gt 30 && $capacity -le 40 ]]; then
        echo "ÔĖá $capacity"
    elif [[ $capacity -gt 40 && $capacity -le 60 ]]; then
        echo "ÔĖą $capacity"
    elif [[ $capacity -gt 60 && $capacity -le 80 ]]; then
        echo "ÔĖČ $capacity"
    elif [[ $capacity -gt 80 && $capacity -le 90 ]]; then
        echo "ÔĖä $capacity"
    elif [[ $capacity -gt 90 ]]; then
        echo "ÔĖĄ $capacity"
    fi
    ;;

Full)
    echo "Ôēł Full"
    ;;
esac
